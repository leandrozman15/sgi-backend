generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_logs {
  id        String   @id(map: "AuditLog_pkey")
  companyId String
  user      String
  module    String
  action    String
  data      Json?
  timestamp DateTime @default(now())

  @@index([companyId], map: "AuditLog_companyId_idx")
}

model carriers {
  id        String    @id(map: "Carrier_pkey")
  companyId String
  nome      String
  data      Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  deletedAt DateTime?

  @@index([companyId, deletedAt], map: "Carrier_companyId_deletedAt_idx")
  @@index([companyId], map: "Carrier_companyId_idx")
}

model clients {
  id        String    @id(map: "Client_pkey")
  companyId String
  nome      String
  data      Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  deletedAt DateTime?

  @@index([companyId, deletedAt], map: "Client_companyId_deletedAt_idx")
  @@index([companyId], map: "Client_companyId_idx")
}

model companies {
  id                     String                   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                   String
  cnpj                   String?                  @unique
  plan                   String?                  @default("basic")
  active                 Boolean?                 @default(true)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime?                @default(now()) @db.Timestamp(6)
  calibrations           calibrations[]
  employees              employees[]
  financial_transactions financial_transactions[]
  machines               machines[]
  production_orders      production_orders[]
  products               products[]
  purchase_requests      purchase_requests[]
  subscription_history   subscription_history[]
  tax_service_payments   tax_service_payments[]
  user_companies         user_companies[]
  users                  users[]
  work_accidents         work_accidents[]
}

model employees {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  name       String
  email      String?   @unique
  document   String?   @unique
  position   String?
  department String?
  status     String?   @default("active")
  company_id String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model financial_transactions {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  type        String
  amount      Decimal   @db.Decimal(10, 2)
  description String?
  date        DateTime  @db.Timestamp(6)
  company_id  String
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  companies   companies @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model inventory_movements {
  id        String   @id(map: "InventoryMovement_pkey")
  companyId String
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([companyId], map: "InventoryMovement_companyId_idx")
}

model machines {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  name       String
  code       String?   @unique
  type       String?
  status     String?   @default("active")
  company_id String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model memberships {
  id        String   @id(map: "Membership_pkey")
  userId    String
  companyId String
  roles     String[]
  createdAt DateTime @default(now())

  @@unique([userId, companyId], map: "Membership_userId_companyId_key")
}

model production_orders {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  number     String    @unique
  product_id String
  quantity   Int
  status     String?   @default("pending")
  company_id String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products   products  @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model products {
  id                String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  name              String
  code              String?             @unique
  description       String?
  price             Decimal?            @db.Decimal(10, 2)
  company_id        String
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  updated_at        DateTime?           @default(now()) @db.Timestamp(6)
  production_orders production_orders[]
  companies         companies           @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model raw_materials {
  id        String    @id(map: "RawMaterial_pkey")
  companyId String
  nome      String
  data      Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  deletedAt DateTime?

  @@index([companyId, deletedAt], map: "RawMaterial_companyId_deletedAt_idx")
  @@index([companyId], map: "RawMaterial_companyId_idx")
}

model sales {
  id        String    @id(map: "Sale_pkey")
  companyId String
  data      Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  deletedAt DateTime?

  @@index([companyId, deletedAt], map: "Sale_companyId_deletedAt_idx")
  @@index([companyId], map: "Sale_companyId_idx")
}

model suppliers {
  id        String    @id(map: "Supplier_pkey")
  companyId String
  nome      String
  data      Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  deletedAt DateTime?

  @@index([companyId, deletedAt], map: "Supplier_companyId_deletedAt_idx")
  @@index([companyId], map: "Supplier_companyId_idx")
}

model user_companies {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  user_id    String
  company_id String
  role       String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, company_id])
}

model users {
  id             String           @id
  email          String           @unique
  name           String?
  role           String?          @default("CONSULTOR")
  company_id     String?
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  user_companies user_companies[]
  companies      companies?       @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model warehouse_locations {
  id         String   @id(map: "WarehouseLocation_pkey")
  companyId  String
  locationId String
  data       Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@unique([companyId, locationId], map: "WarehouseLocation_companyId_locationId_key")
  @@index([companyId], map: "WarehouseLocation_companyId_idx")
}

model calibrations {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id String
  data       Json?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model purchase_requests {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id String
  data       Json?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model subscription_history {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id String
  data       Json?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model tax_service_payments {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id String
  data       Json?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model work_accidents {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id String
  data       Json?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}
