generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_logs {
  id        String   @id(map: "AuditLog_pkey")
  companyId String
  user      String
  module    String
  action    String
  data      Json?
  timestamp DateTime @default(now())

  @@index([companyId], map: "AuditLog_companyId_idx")
}

model carriers {
  id        String    @id(map: "Carrier_pkey")
  companyId String
  nome      String
  data      Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  deletedAt DateTime?
  cnpj      String?
  contacts  Json?
  endereco  Json?
  ie        String?

  @@index([companyId, deletedAt], map: "Carrier_companyId_deletedAt_idx")
  @@index([companyId], map: "Carrier_companyId_idx")
}

model clients {
  id        String    @id(map: "Client_pkey")
  companyId String
  nome      String
  data      Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  deletedAt DateTime?

  @@index([companyId, deletedAt], map: "Client_companyId_deletedAt_idx")
  @@index([companyId], map: "Client_companyId_idx")
}

model companies {
  id                                String                           @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                              String
  cnpj                              String?                          @unique
  plan                              String?                          @default("basic")
  active                            Boolean?                         @default(true)
  created_at                        DateTime?                        @default(now()) @db.Timestamp(6)
  updated_at                        DateTime?                        @default(now()) @db.Timestamp(6)
  brasil_nfe_personal_token         String?
  brasil_nfe_company_token          String?
  brasil_nfe_credentials_updated_at DateTime?                        @db.Timestamptz(6)
  accounting_accounts_payable       accounting_accounts_payable[]
  accounting_accounts_receivable    accounting_accounts_receivable[]
  accounting_chart_accounts         accounting_chart_accounts[]
  accounting_cost_centers           accounting_cost_centers[]
  accounting_fiscal_periods         accounting_fiscal_periods[]
  accounting_journal_entries        accounting_journal_entries[]
  accounting_journal_entry_lines    accounting_journal_entry_lines[]
  calibrations                      calibrations[]
  employees                         employees[]
  financial_bank_transactions       financial_bank_transactions[]
  financial_salary_payments         financial_salary_payments[]
  financial_transactions            financial_transactions[]
  fiscal_tax_apportionments         fiscal_tax_apportionments[]
  hr_attendance_records             hr_attendance_records[]
  hr_benefit_controls               hr_benefit_controls[]
  hr_benefit_services               hr_benefit_services[]
  hr_benefits                       hr_benefits[]
  hr_epi_deliveries                 hr_epi_deliveries[]
  hr_overtime_records               hr_overtime_records[]
  hr_production_coverages           hr_production_coverages[]
  hr_training_matrix_entries        hr_training_matrix_entries[]
  hr_vacations                      hr_vacations[]
  hr_work_accidents                 hr_work_accidents[]
  inventory_lot_movements           inventory_lot_movements[]
  inventory_lots                    inventory_lots[]
  inventory_reservations            inventory_reservations[]
  inventory_stock_balances          inventory_stock_balances[]
  inventory_storage_positions       inventory_storage_positions[]
  inventory_storage_zones           inventory_storage_zones[]
  inventory_warehouse_layouts       inventory_warehouse_layouts[]
  machine_documents                 machine_documents[]
  machine_meter_readings            machine_meter_readings[]
  machines                          machines[]
  maintenance_downtimes             maintenance_downtimes[]
  maintenance_plans                 maintenance_plans[]
  maintenance_schedules             maintenance_schedules[]
  maintenance_work_order_parts      maintenance_work_order_parts[]
  maintenance_work_orders           maintenance_work_orders[]
  product_variants                  product_variants[]
  production_orders                 production_orders[]
  products                          products[]
  purchase_orders                   purchase_orders[]
  purchase_requests                 purchase_requests[]
  quality_complaints                quality_complaints[]
  quality_inspections               quality_inspections[]
  sale_items                        sale_items[]
  sale_status_history               sale_status_history[]
  sales_fiscal_documents            sales_fiscal_documents[]
  sales_fiscal_events               sales_fiscal_events[]
  sales_nfse_documents              sales_nfse_documents[]
  sales_nfse_events                 sales_nfse_events[]
  subscription_history              subscription_history[]
  tax_service_payments              tax_service_payments[]
  user_companies                    user_companies[]
  users                             users[]
  work_accidents                    work_accidents[]
  shifts                            shifts[]
  work_teams                        work_teams[]
  company_info                      company_info[]
  scraps                            scraps[]
  commissions                       commissions[]
  calendar_events                   calendar_events[]
  dashboard_messages                dashboard_messages[]
  payroll_configs                   payroll_configs[]
}

model employees {
  id                  String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                String
  email               String?
  document            String?
  position            String?
  department          String?
  status              String?   @default("active")
  company_id          String
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)
  access_level        String?
  address             String?
  banco               String?
  commission          Decimal?  @db.Decimal(10, 2)
  conta               String?
  cpf                 String?
  data                Json?
  has_access          Boolean?  @default(false)
  numero_botas        String?
  permissions         Json?
  phone               String?
  pix                 String?
  registration_number String?
  role                String?
  start_date          DateTime? @db.Timestamp(6)
  tamanho_calca       String?
  tamanho_camisa      String?
  vacation_days       Int?
  companies           companies @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([company_id, email])
  @@unique([company_id, document])
}

model financial_transactions {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  type        String
  amount      Decimal   @db.Decimal(10, 2)
  description String?
  date        DateTime  @db.Timestamp(6)
  company_id  String
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  companies   companies @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model financial_bank_transactions {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id       String
  transaction_type String
  category         String?
  description      String?
  amount           Decimal   @db.Decimal(14, 4)
  transaction_date DateTime  @db.Timestamptz(6)
  due_date         DateTime? @db.Timestamptz(6)
  payment_method   String?
  account_name     String?
  status           String?   @default("PENDING")
  reference_type   String?
  reference_id     String?
  notes            String?
  data             Json?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
  companies        companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([transaction_date])
  @@index([status])
  @@index([transaction_type])
}

model financial_salary_payments {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id       String
  employee_id      String?
  employee_name    String?
  period_reference String?
  payroll_date     DateTime? @db.Timestamptz(6)
  gross_amount     Decimal?  @db.Decimal(14, 4)
  discounts_amount Decimal?  @db.Decimal(14, 4)
  net_amount       Decimal?  @db.Decimal(14, 4)
  payment_date     DateTime? @db.Timestamptz(6)
  payment_method   String?
  status           String?   @default("PENDING")
  notes            String?
  data             Json?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
  companies        companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([employee_id])
  @@index([period_reference])
  @@index([status])
}

model inventory_movements {
  id        String   @id(map: "InventoryMovement_pkey")
  companyId String
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([companyId], map: "InventoryMovement_companyId_idx")
}

model machines {
  id                      String                    @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                    String
  code                    String?
  type                    String?
  status                  String?                   @default("active")
  company_id              String
  created_at              DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at              DateTime?                 @default(now()) @db.Timestamp(6)
  acquisition_date        DateTime?                 @db.Timestamp(6)
  archived                Boolean?                  @default(false)
  critical_spares         String?
  data                    Json?
  installation_date       DateTime?                 @db.Timestamp(6)
  last_maintenance        DateTime?                 @db.Timestamp(6)
  location                String?
  lubrication_points      String?
  lubrication_reqs        String?
  main_risks              String?
  maintenance_history     Json?
  maintenance_intervals   String?
  maintenance_notes       String?
  manual_url              String?
  manufacturer            String?
  model                   String?
  next_maintenance        DateTime?                 @db.Timestamp(6)
  other_inputs            String?
  power_kw                Decimal?                  @db.Decimal(10, 3)
  pressure_bar            Decimal?                  @db.Decimal(10, 3)
  required_epp            String?
  rotation_rpm            Decimal?                  @db.Decimal(10, 3)
  sector                  String?
  serial_number           String?
  tag                     String?
  temperature_range       String?
  voltage_v               Decimal?                  @db.Decimal(10, 3)
  warranty_until          DateTime?                 @db.Timestamp(6)
  machine_documents       machine_documents[]
  machine_meter_readings  machine_meter_readings[]
  companies               companies                 @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  maintenance_downtimes   maintenance_downtimes[]
  maintenance_plans       maintenance_plans[]
  maintenance_schedules   maintenance_schedules[]
  maintenance_work_orders maintenance_work_orders[]

  @@unique([company_id, code])
}

model maintenance_plans {
  id                    String                  @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id            String
  machine_id            String
  title                 String
  description           String?
  maintenance_type      String?
  frequency_unit        String?
  frequency_value       Int?
  estimated_hours       Decimal?                @db.Decimal(10, 2)
  checklist             Json?
  required_parts        Json?
  active                Boolean?                @default(true)
  last_executed_at      DateTime?               @db.Timestamp(6)
  next_due_at           DateTime?               @db.Timestamp(6)
  data                  Json?
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  updated_at            DateTime                @default(now()) @db.Timestamp(6)
  companies             companies               @relation(fields: [company_id], references: [id], onDelete: Cascade)
  machines              machines                @relation(fields: [machine_id], references: [id], onDelete: Cascade)
  maintenance_schedules maintenance_schedules[]

  @@index([company_id])
  @@index([machine_id])
  @@index([company_id, machine_id], map: "maintenance_plans_company_machine_idx")
}

model maintenance_schedules {
  id                      String                    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id              String
  machine_id              String
  maintenance_plan_id     String?
  scheduled_for           DateTime                  @db.Timestamp(6)
  assigned_to_employee_id String?
  priority                String?
  status                  String?                   @default("scheduled")
  notes                   String?
  recurrence_snapshot     Json?
  data                    Json?
  created_at              DateTime                  @default(now()) @db.Timestamp(6)
  updated_at              DateTime                  @default(now()) @db.Timestamp(6)
  companies               companies                 @relation(fields: [company_id], references: [id], onDelete: Cascade)
  machines                machines                  @relation(fields: [machine_id], references: [id], onDelete: Cascade)
  maintenance_plans       maintenance_plans?        @relation(fields: [maintenance_plan_id], references: [id])
  maintenance_work_orders maintenance_work_orders[]

  @@index([company_id])
  @@index([machine_id])
  @@index([scheduled_for])
  @@index([status])
}

model maintenance_work_orders {
  id                           String                         @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id                   String
  machine_id                   String
  maintenance_schedule_id      String?
  order_number                 String?
  maintenance_type             String?
  priority                     String?
  status                       String?                        @default("open")
  opened_at                    DateTime?                      @db.Timestamp(6)
  started_at                   DateTime?                      @db.Timestamp(6)
  finished_at                  DateTime?                      @db.Timestamp(6)
  reported_by                  String?
  assigned_to                  String?
  approved_by                  String?
  failure_mode                 String?
  root_cause                   String?
  actions_taken                String?
  observations                 String?
  downtime_minutes             Int?
  labor_cost                   Decimal?                       @db.Decimal(12, 2)
  parts_cost                   Decimal?                       @db.Decimal(12, 2)
  external_cost                Decimal?                       @db.Decimal(12, 2)
  total_cost                   Decimal?                       @db.Decimal(12, 2)
  data                         Json?
  created_at                   DateTime                       @default(now()) @db.Timestamp(6)
  updated_at                   DateTime                       @default(now()) @db.Timestamp(6)
  maintenance_downtimes        maintenance_downtimes[]
  maintenance_work_order_parts maintenance_work_order_parts[]
  companies                    companies                      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  machines                     machines                       @relation(fields: [machine_id], references: [id], onDelete: Cascade)
  maintenance_schedules        maintenance_schedules?         @relation(fields: [maintenance_schedule_id], references: [id])

  @@index([company_id])
  @@index([machine_id])
  @@index([maintenance_schedule_id], map: "maintenance_work_orders_schedule_id_idx")
  @@index([status])
  @@index([order_number])
}

model maintenance_work_order_parts {
  id                        String                  @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id                String
  maintenance_work_order_id String
  raw_material_id           String?
  product_id                String?
  description               String?
  quantity                  Decimal?                @db.Decimal(12, 4)
  unit_cost                 Decimal?                @db.Decimal(12, 4)
  total_cost                Decimal?                @db.Decimal(12, 4)
  data                      Json?
  created_at                DateTime                @default(now()) @db.Timestamp(6)
  updated_at                DateTime                @default(now()) @db.Timestamp(6)
  companies                 companies               @relation(fields: [company_id], references: [id], onDelete: Cascade)
  maintenance_work_orders   maintenance_work_orders @relation(fields: [maintenance_work_order_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([maintenance_work_order_id], map: "maintenance_work_order_parts_order_id_idx")
  @@index([raw_material_id])
  @@index([product_id])
}

model machine_meter_readings {
  id            String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id    String
  machine_id    String
  meter_type    String
  reading_value Decimal   @db.Decimal(14, 4)
  unit          String?
  reading_at    DateTime  @db.Timestamp(6)
  notes         String?
  data          Json?
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime  @default(now()) @db.Timestamp(6)
  companies     companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  machines      machines  @relation(fields: [machine_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([machine_id])
  @@index([meter_type])
  @@index([reading_at])
}

model maintenance_downtimes {
  id                        String                   @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id                String
  machine_id                String
  maintenance_work_order_id String?
  category                  String?
  reason                    String?
  planned                   Boolean?                 @default(false)
  started_at                DateTime                 @db.Timestamp(6)
  ended_at                  DateTime?                @db.Timestamp(6)
  duration_minutes          Int?
  impact_level              String?
  notes                     String?
  data                      Json?
  created_at                DateTime                 @default(now()) @db.Timestamp(6)
  updated_at                DateTime                 @default(now()) @db.Timestamp(6)
  companies                 companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  machines                  machines                 @relation(fields: [machine_id], references: [id], onDelete: Cascade)
  maintenance_work_orders   maintenance_work_orders? @relation(fields: [maintenance_work_order_id], references: [id])

  @@index([company_id])
  @@index([machine_id])
  @@index([maintenance_work_order_id], map: "maintenance_downtimes_work_order_id_idx")
  @@index([started_at])
}

model machine_documents {
  id            String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id    String
  machine_id    String
  document_type String?
  title         String
  file_url      String
  file_name     String?
  version       String?
  issued_at     DateTime? @db.Timestamp(6)
  expires_at    DateTime? @db.Timestamp(6)
  uploaded_by   String?
  data          Json?
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime  @default(now()) @db.Timestamp(6)
  companies     companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  machines      machines  @relation(fields: [machine_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([machine_id])
  @@index([document_type])
}

model memberships {
  id        String   @id(map: "Membership_pkey")
  userId    String
  companyId String
  roles     String[]
  createdAt DateTime @default(now())

  @@unique([userId, companyId], map: "Membership_userId_companyId_key")
}

model production_orders {
  id         String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  number     String
  product_id String
  quantity   Int
  status     String?           @default("pending")
  company_id String
  created_at DateTime?         @default(now()) @db.Timestamp(6)
  updated_at DateTime?         @default(now()) @db.Timestamp(6)
  variant_id String?
  data       Json?
  companies  companies         @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products   products          @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variants   product_variants? @relation(fields: [variant_id], references: [id], onUpdate: NoAction)

  @@unique([company_id, number])
  @@index([variant_id])
}

model products {
  id                           String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                         String
  code                         String?
  description                  String?
  price                        Decimal?            @db.Decimal(10, 2)
  company_id                   String
  created_at                   DateTime?           @default(now()) @db.Timestamp(6)
  updated_at                   DateTime?           @default(now()) @db.Timestamp(6)
  aliquota_cbs                 Decimal?            @db.Decimal(10, 4)
  aliquota_ibs_mun             Decimal?            @db.Decimal(10, 4)
  aliquota_ibs_uf              Decimal?            @db.Decimal(10, 4)
  cest                         String?
  cfop                         String?
  cod_classificacao_tributaria String?
  cofins_aliquota              Decimal?            @db.Decimal(10, 4)
  cofins_situacao_tributaria   String?
  country_of_origin            String?
  csosn                        String?
  current_stock                Int?
  customer_barcode             String?
  dangerous_goods_class        String?
  data                         Json?
  gs1_code                     String?
  icms_aliquota                Decimal?            @db.Decimal(10, 4)
  icms_modalidade_bc           String?
  image_urls                   Json?
  ipi_aliquota                 Decimal?            @db.Decimal(10, 4)
  ipi_cod_enquadramento        String?
  ipi_situacao_tributaria      String?
  mva_aliquota                 Decimal?            @db.Decimal(10, 4)
  ncm                          String?
  origem_mercadoria            String?
  pis_aliquota                 Decimal?            @db.Decimal(10, 4)
  pis_situacao_tributaria      String?
  published                    Boolean?            @default(false)
  raw_materials                Json?
  sku                          String?
  stages                       Json?
  sujeito_icms_st              Boolean?
  technical_specs              Json?
  type                         String?
  unidade_tributavel           String?
  valor_icms_st                Decimal?            @db.Decimal(12, 4)
  variants                     Json?
  weight                       Decimal?            @db.Decimal(10, 3)
  base_calculo_ibs_cbs         Decimal?            @db.Decimal(14, 4)
  product_variants             product_variants[]
  production_orders            production_orders[]
  companies                    companies           @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([company_id, code])
}

model product_variants {
  id                String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  product_id        String
  company_id        String
  name              String
  sku               String?
  code              String?
  price             Decimal?            @db.Decimal(12, 4)
  data              Json?
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  updated_at        DateTime?           @default(now()) @db.Timestamp(6)
  companies         companies           @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products          products            @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  production_orders production_orders[]

  @@index([product_id], map: "ProductVariant_product_id_idx")
  @@index([company_id], map: "ProductVariant_company_id_idx")
}

model raw_materials {
  id                         String           @id(map: "RawMaterial_pkey")
  companyId                  String
  nome                       String
  data                       Json?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime
  deletedAt                  DateTime?
  aliquotaCBS                Decimal?         @db.Decimal(10, 4)
  aliquotaIBSMun             Decimal?         @db.Decimal(10, 4)
  aliquotaIBSUF              Decimal?         @db.Decimal(10, 4)
  cest                       String?
  cfop                       String?
  codClassificacaoTributaria String?
  code                       String?
  cofinsAliquota             Decimal?         @db.Decimal(10, 4)
  cofinsSituacaoTributaria   String?
  csosn                      String?
  currentStock               Decimal?         @db.Decimal(12, 4)
  customerBarcode            String?
  dangerousGoodsClass        String?
  fatorConversao             Decimal?         @db.Decimal(12, 4)
  fornecedores               Json?
  group                      String?
  gs1Code                    String?
  icmsAliquota               Decimal?         @db.Decimal(10, 4)
  icmsModalidadeBC           String?
  ipiAliquota                Decimal?         @db.Decimal(10, 4)
  ipiCodEnquadramento        String?
  ipiSituacaoTributaria      String?
  localizacaoEstoque         String?
  lote                       String?
  maxStock                   Decimal?         @db.Decimal(12, 4)
  minStock                   Decimal?         @db.Decimal(12, 4)
  mvaAliquota                Decimal?         @db.Decimal(10, 4)
  ncm                        String?
  obsTecnicas                String?
  origem                     String?
  pisAliquota                Decimal?         @db.Decimal(10, 4)
  pisSituacaoTributaria      String?
  sku                        String?
  sujeitoIcmsSt              Boolean?
  tipoMaterial               String?
  unidadeConsumo             String?
  unidadeTributavel          String?
  validadeDias               Int?
  valorIcmsSt                Decimal?         @db.Decimal(12, 4)
  weight                     Decimal?         @db.Decimal(12, 4)
  inventory_lots             inventory_lots[]

  @@index([companyId, deletedAt], map: "RawMaterial_companyId_deletedAt_idx")
  @@index([companyId], map: "RawMaterial_companyId_idx")
  @@index([companyId, code], map: "RawMaterial_company_code_idx")
}

model sales {
  id               String                   @id(map: "Sale_pkey")
  companyId        String
  data             Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime
  deletedAt        DateTime?
  items            sale_items[]
  history          sale_status_history[]
  fiscal_documents sales_fiscal_documents[]
  nfse_documents   sales_nfse_documents[]

  @@index([companyId, deletedAt], map: "Sale_companyId_deletedAt_idx")
  @@index([companyId], map: "Sale_companyId_idx")
}

model sale_items {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id      String
  sale_id         String
  line_number     Int?
