# Runtime
NODE_ENV=production
PORT=10000

# Public app URL and CORS allowlist (comma-separated)
APP_PUBLIC_URL=https://studio--your-project.us-central1.hosted.app
CORS_ORIGIN=https://studio--your-project.us-central1.hosted.app,https://your-frontend-domain.com

# Database
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional: list of UID values with super-admin access
SUPER_ADMIN_UIDS=
